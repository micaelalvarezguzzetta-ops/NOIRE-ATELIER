      font-size: 10px; letter-spacing: 0.4em; text-transform: uppercase;
      cursor: none; font-weight: 500; transition: background 0.3s;
    }
    .checkout-btn:hover { background: var(--gold-light); }

    /* ── SIZE SELECTOR MODAL ── */
    .modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.8);
      z-index: 300; opacity: 0; pointer-events: none;
      transition: opacity 0.3s;
      display: flex; align-items: center; justify-content: center;
    }
    .modal-overlay.show { opacity: 1; pointer-events: all; }
    .modal {
      background: #0e0e0e; border: 1px solid var(--border);
      max-width: 500px; width: 90%; padding: 48px;
      transform: translateY(20px); transition: transform 0.3s;
    }
    .modal-overlay.show .modal { transform: translateY(0); }
    .modal-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 28px; font-weight: 300; color: var(--cream);
      margin-bottom: 6px; letter-spacing: 0.05em;
