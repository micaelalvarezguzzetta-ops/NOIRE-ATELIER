<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NOIRÈ ATELIER — Designed with Intention</title>
  <meta name="description" content="NOIRÈ Atelier — Ropa premium unisex diseñada con intención. Hoodies y camisetas exclusivas. Est. 2024." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Montserrat:wght@200;300;400;500&display=swap" rel="stylesheet" />

  <style>
    :root {
      --noir: #0a0a0a;
      --noir-soft: #111111;
      --cream: #f0ece4;
      --cream-dim: #c8c0b4;
      --gold: #c9a96e;
      --gold-light: #e2c98a;
      --blue-royal: #1a3bb5;
      --blue-sky: #b0c8e8;
      --burgundy: #6b1f2e;
      --grey-mid: #888880;
      --border: rgba(240,236,228,0.12);
      --border-hover: rgba(201,169,110,0.4);
    }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--noir);
      color: var(--cream);
      font-family: 'Montserrat', sans-serif;
      font-weight: 300;
      overflow-x: hidden;
      cursor: none;
    }

    /* ── CUSTOM CURSOR ── */
    .cursor {
      position: fixed; width: 10px; height: 10px;
      background: var(--gold); border-radius: 50%;
      pointer-events: none; z-index: 9999;
      transform: translate(-50%, -50%);
      transition: transform 0.1s ease, width 0.3s ease, height 0.3s ease, opacity 0.3s ease;
      mix-blend-mode: difference;
    }
    .cursor-ring {
      position: fixed; width: 36px; height: 36px;
      border: 1px solid var(--gold); border-radius: 50%;
      pointer-events: none; z-index: 9998;
      transform: translate(-50%, -50%);
      transition: all 0.18s ease;
      opacity: 0.6;
    }
    body:hover .cursor { opacity: 1; }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar { width: 2px; }
    ::-webkit-scrollbar-track { background: var(--noir); }
    ::-webkit-scrollbar-thumb { background: var(--gold); }

    /* ── HEADER / NAV ── */
    header {
      position: fixed; top: 0; left: 0; width: 100%;
      z-index: 100; padding: 0 48px;
      display: flex; align-items: center; justify-content: space-between;
      height: 72px;
      background: linear-gradient(to bottom, rgba(10,10,10,0.95) 0%, transparent 100%);
      backdrop-filter: blur(0px);
      transition: background 0.4s ease, backdrop-filter 0.4s ease;
    }
    header.scrolled {
      background: rgba(10,10,10,0.97);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }

    .nav-links {
      display: flex; gap: 36px; list-style: none;
    }
    .nav-links a {
      color: var(--cream-dim); text-decoration: none;
      font-family: 'Montserrat', sans-serif;
      font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
      font-weight: 400;
      transition: color 0.3s;
      position: relative;
    }
    .nav-links a::after {
      content: ''; position: absolute; bottom: -4px; left: 0;
      width: 0; height: 1px; background: var(--gold);
      transition: width 0.3s ease;
    }
    .nav-links a:hover { color: var(--gold); }
    .nav-links a:hover::after { width: 100%; }

    .nav-brand {
      position: absolute; left: 50%; transform: translateX(-50%);
      text-align: center; line-height: 1;
    }
    .nav-brand .brand-m {
      font-family: 'Cormorant Garamond', serif;
      font-size: 13px; font-weight: 400; letter-spacing: 0.3em;
      display: block; color: var(--cream);
    }
    .nav-brand .brand-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 20px; font-weight: 500; letter-spacing: 0.25em;
      display: block; color: var(--cream);
    }
    .nav-brand .brand-sub {
      font-size: 8px; letter-spacing: 0.4em; color: var(--gold);
      font-family: 'Montserrat', sans-serif; font-weight: 300;
    }

    .nav-icons {
      display: flex; gap: 24px; align-items: center;
    }
    .nav-icon {
      color: var(--cream-dim); cursor: none; font-size: 13px;
      letter-spacing: 0.15em; font-size: 10px; text-transform: uppercase;
      transition: color 0.3s; background: none; border: none;
    }
    .nav-icon:hover { color: var(--gold); }
    .cart-count {
      display: inline-flex; align-items: center; justify-content: center;
      width: 16px; height: 16px; background: var(--gold);
      color: var(--noir); border-radius: 50%; font-size: 8px;
      font-weight: 500; margin-left: 4px;
    }

    /* ── HERO ── */
    .hero {
      position: relative; height: 100vh; min-height: 700px;
      display: flex; align-items: flex-end; overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background-image: url('img/hoodie-burdeos.png');
      background-size: cover; background-position: center top;
      filter: brightness(0.55);
      transform: scale(1.05);
      animation: heroZoom 12s ease-out forwards;
    }
    @keyframes heroZoom {
      from { transform: scale(1.08); }
      to { transform: scale(1.0); }
    }
    .hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(
        to top,
        rgba(10,10,10,0.92) 0%,
        rgba(10,10,10,0.3) 40%,
        transparent 70%
      );
    }
    .hero-content {
      position: relative; z-index: 2;
      padding: 0 80px 80px;
      max-width: 700px;
      opacity: 0; animation: heroFadeUp 1.2s 0.5s forwards ease-out;
    }
    @keyframes heroFadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .hero-label {
      font-size: 9px; letter-spacing: 0.5em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 18px; font-weight: 400;
    }
    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(52px, 8vw, 96px);
      font-weight: 300; line-height: 0.9;
      color: var(--cream); margin-bottom: 24px;
      letter-spacing: -0.01em;
    }
    .hero-title em { font-style: italic; color: var(--gold-light); }
    .hero-desc {
      font-size: 11px; letter-spacing: 0.15em; color: var(--cream-dim);
      line-height: 2; max-width: 400px; margin-bottom: 40px;
      text-transform: uppercase;
    }
    .hero-cta {
      display: inline-flex; align-items: center; gap: 16px;
    }
    .btn-primary {
      padding: 14px 40px; border: 1px solid var(--gold);
      background: transparent; color: var(--gold);
      font-family: 'Montserrat', sans-serif;
      font-size: 9px; letter-spacing: 0.35em; text-transform: uppercase;
      cursor: none; text-decoration: none;
      transition: all 0.35s ease;
      font-weight: 400;
    }
    .btn-primary:hover {
      background: var(--gold); color: var(--noir);
    }
    .btn-ghost {
      color: var(--cream-dim); font-size: 9px; letter-spacing: 0.3em;
      text-transform: uppercase; text-decoration: none;
      font-family: 'Montserrat', sans-serif;
      display: flex; align-items: center; gap: 10px;
      transition: color 0.3s;
    }
    .btn-ghost:hover { color: var(--cream); }
    .btn-ghost::after { content: '→'; font-size: 14px; }

    .hero-scroll-indicator {
      position: absolute; bottom: 36px; right: 60px;
      display: flex; flex-direction: column; align-items: center; gap: 10px;
      opacity: 0; animation: heroFadeUp 1s 1.5s forwards;
    }
    .scroll-line {
      width: 1px; height: 60px;
      background: linear-gradient(to bottom, var(--gold), transparent);
      animation: scrollPulse 2s infinite;
    }
    @keyframes scrollPulse {
      0%, 100% { opacity: 0.4; } 50% { opacity: 1; }
    }
    .scroll-text {
      writing-mode: vertical-rl; font-size: 8px; letter-spacing: 0.3em;
      color: var(--gold); text-transform: uppercase; font-weight: 300;
    }

    /* ── MARQUEE STRIP ── */
    .marquee-strip {
      background: var(--gold);
      padding: 12px 0; overflow: hidden;
      white-space: nowrap;
    }
    .marquee-inner {
      display: inline-flex; gap: 0;
      animation: marqueeScroll 20s linear infinite;
    }
    @keyframes marqueeScroll {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }
    .marquee-item {
      display: inline-flex; align-items: center; gap: 32px;
      padding: 0 32px;
      font-size: 9px; letter-spacing: 0.4em; text-transform: uppercase;
      color: var(--noir); font-weight: 500;
    }
    .marquee-dot { width: 4px; height: 4px; background: var(--noir); border-radius: 50%; }

    /* ── SECTION HEADER ── */
    .section-head {
      text-align: center; padding: 90px 48px 60px;
    }
    .section-label {
      font-size: 8px; letter-spacing: 0.5em; color: var(--gold);
      text-transform: uppercase; margin-bottom: 16px; display: block;
    }
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(36px, 5vw, 64px);
      font-weight: 300; letter-spacing: 0.02em;
      color: var(--cream); line-height: 1.1;
    }
    .section-title em { font-style: italic; color: var(--gold-light); }
    .section-divider {
      display: flex; align-items: center; justify-content: center;
      gap: 16px; margin-top: 24px;
    }
    .divider-line { width: 60px; height: 1px; background: var(--gold); opacity: 0.4; }
    .divider-icon { color: var(--gold); font-size: 10px; letter-spacing: 0.2em; opacity: 0.7; }

    /* ── PRODUCT GRID ── */
    .products-section { padding: 0 48px 100px; }
    
    .filter-bar {
      display: flex; gap: 4px; justify-content: center;
      margin-bottom: 52px;
    }
    .filter-btn {
      padding: 8px 24px; background: none; border: 1px solid transparent;
      color: var(--cream-dim); font-family: 'Montserrat', sans-serif;
      font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase;
      cursor: none; transition: all 0.3s; font-weight: 400;
    }
    .filter-btn.active, .filter-btn:hover {
      border-color: var(--gold); color: var(--gold);
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      max-width: 1400px; margin: 0 auto;
    }
    .products-grid .product-card:nth-child(1) { grid-column: span 1; }
    .products-grid .product-card:nth-child(2) { grid-column: span 1; }
    .products-grid .product-card:nth-child(3) { grid-column: span 1; }

    .product-card {
      position: relative; overflow: hidden;
      background: #0e0e0e;
      cursor: none;
    }
    .product-card::before {
      content: ''; position: absolute; inset: 0;
      border: 1px solid transparent;
      transition: border-color 0.4s ease; z-index: 3;
      pointer-events: none;
    }
    .product-card:hover::before { border-color: var(--gold); }

    .product-img-wrap {
      position: relative; overflow: hidden;
      aspect-ratio: 3/4;
    }
    .product-img-wrap img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      filter: brightness(0.9);
    }
    .product-card:hover .product-img-wrap img {
      transform: scale(1.06);
      filter: brightness(1);
    }

    .product-badge {
      position: absolute; top: 20px; left: 20px;
      background: var(--gold); color: var(--noir);
      font-size: 7px; letter-spacing: 0.3em; text-transform: uppercase;
      padding: 5px 12px; font-weight: 500; z-index: 2;
    }
    .product-badge.new { background: var(--cream); }
    .product-badge.limited { background: var(--burgundy); color: var(--cream-dim); }

    .product-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(10,10,10,0.85) 0%, transparent 50%);
      opacity: 0; transition: opacity 0.4s ease; z-index: 2;
      display: flex; align-items: flex-end; justify-content: center;
      padding-bottom: 28px; gap: 12px;
    }
    .product-card:hover .product-overlay { opacity: 1; }
    .overlay-btn {
      padding: 10px 22px; font-size: 8px; letter-spacing: 0.3em;
      text-transform: uppercase; cursor: none; font-weight: 400;
      font-family: 'Montserrat', sans-serif;
      transition: all 0.25s;
    }
    .overlay-btn-main {
      background: var(--gold); color: var(--noir); border: none;
    }
    .overlay-btn-main:hover { background: var(--gold-light); }
    .overlay-btn-wish {
      background: transparent; color: var(--cream);
      border: 1px solid rgba(240,236,228,0.4);
    }
    .overlay-btn-wish:hover { border-color: var(--cream); }

    .product-info {
      padding: 20px 20px 24px;
      border-top: 1px solid var(--border);
    }
    .product-cat {
      font-size: 8px; letter-spacing: 0.35em; color: var(--gold);
      text-transform: uppercase; margin-bottom: 6px;
    }
    .product-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 20px; font-weight: 400; color: var(--cream);
      margin-bottom: 4px; letter-spacing: 0.03em;
    }
    .product-variant { font-size: 9px; color: var(--grey-mid); letter-spacing: 0.15em; margin-bottom: 14px; }
    .product-footer {
      display: flex; justify-content: space-between; align-items: center;
    }
    .product-price {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px; font-weight: 400; color: var(--cream);
    }
    .product-colors { display: flex; gap: 6px; }
    .color-swatch {
      width: 12px; height: 12px; border-radius: 50%;
      border: 1px solid rgba(240,236,228,0.2);
      cursor: none; transition: transform 0.2s;
    }
    .color-swatch:hover { transform: scale(1.3); }

    /* ── SECOND ROW — WIDE CARDS ── */
    .products-grid-row2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      max-width: 1400px; margin: 2px auto 0;
    }

    /* ── EDITORIAL BANNER ── */
    .editorial-banner {
      margin: 80px 0;
      position: relative; overflow: hidden;
      height: 85vh; min-height: 600px;
    }
    .editorial-bg {
      position: absolute; inset: 0;
      background-image: url('img/hoodie-azul-cielo-loft.jpg');
      background-size: cover; background-position: center 20%;
      filter: brightness(0.45);
      transition: transform 0.8s ease;
    }
    .editorial-banner:hover .editorial-bg { transform: scale(1.02); }
    .editorial-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(10,10,10,0.7) 0%, rgba(26,59,181,0.15) 100%);
    }
    .editorial-content {
      position: relative; z-index: 2; height: 100%;
      display: flex; flex-direction: column;
      justify-content: center; align-items: flex-start;
      padding: 80px;
      max-width: 600px;
    }
    .editorial-tag {
      display: inline-block; border: 1px solid var(--gold);
      padding: 6px 16px; font-size: 8px; letter-spacing: 0.5em;
      text-transform: uppercase; color: var(--gold); margin-bottom: 28px;
    }
    .editorial-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(44px, 6vw, 80px);
      font-weight: 300; line-height: 1; color: var(--cream);
      margin-bottom: 24px; letter-spacing: -0.01em;
    }
    .editorial-title em { font-style: italic; color: var(--gold-light); }
    .editorial-desc {
      font-size: 10px; letter-spacing: 0.18em; color: var(--cream-dim);
      line-height: 2.2; max-width: 380px; margin-bottom: 36px;
      text-transform: uppercase;
    }

    /* ── BRAND VALUES ── */
    .values-section {
      padding: 90px 80px;
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 1px; background: var(--border);
    }
    .value-card {
      background: var(--noir); padding: 48px 36px;
      text-align: center; transition: background 0.4s;
    }
    .value-card:hover { background: #121212; }
    .value-icon {
      font-family: 'Cormorant Garamond', serif;
      font-size: 48px; font-weight: 300; color: var(--gold);
      line-height: 1; margin-bottom: 20px; display: block;
    }
    .value-title {
      font-size: 9px; letter-spacing: 0.4em; text-transform: uppercase;
      color: var(--cream); margin-bottom: 12px; font-weight: 500;
    }
    .value-desc {
      font-size: 10px; color: var(--grey-mid); letter-spacing: 0.08em;
      line-height: 1.8;
    }

    /* ── SIZE GUIDE STRIP ── */
    .size-strip {
      padding: 60px 80px;
      display: flex; align-items: center; justify-content: space-between;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .size-strip-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 32px; font-weight: 300; color: var(--cream);
    }
    .size-strip-text em { font-style: italic; color: var(--gold); }
    .size-pills { display: flex; gap: 8px; }
    .size-pill {
      width: 44px; height: 44px; border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 9px; letter-spacing: 0.1em; color: var(--cream-dim);
      cursor: none; transition: all 0.25s;
    }
    .size-pill:hover { border-color: var(--gold); color: var(--gold); }

    /* ── NEWSLETTER ── */
    .newsletter {
      padding: 100px 80px;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: center;
    }
    .newsletter-left .section-label { text-align: left; }
    .newsletter-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(36px, 4vw, 56px);
      font-weight: 300; color: var(--cream); line-height: 1.1;
      margin-bottom: 16px;
    }
    .newsletter-title em { font-style: italic; color: var(--gold); }
    .newsletter-sub {
      font-size: 10px; color: var(--grey-mid); letter-spacing: 0.15em;
      line-height: 2; text-transform: uppercase;
    }
    .newsletter-form {
      display: flex; flex-direction: column; gap: 16px;
    }
    .newsletter-input {
      background: transparent; border: none;
      border-bottom: 1px solid var(--border);
      padding: 14px 0; color: var(--cream);
      font-family: 'Montserrat', sans-serif;
      font-size: 11px; letter-spacing: 0.15em;
      outline: none; transition: border-color 0.3s;
    }
    .newsletter-input::placeholder { color: var(--grey-mid); font-size: 10px; letter-spacing: 0.2em; }
    .newsletter-input:focus { border-bottom-color: var(--gold); }
    .newsletter-submit {
      align-self: flex-start; margin-top: 8px;
      padding: 14px 48px; background: var(--gold);
      border: none; color: var(--noir);
      font-family: 'Montserrat', sans-serif;
      font-size: 9px; letter-spacing: 0.35em; text-transform: uppercase;
      cursor: none; font-weight: 500; transition: all 0.3s;
    }
    .newsletter-submit:hover { background: var(--gold-light); }
    .newsletter-note {
      font-size: 8px; color: var(--grey-mid); letter-spacing: 0.15em;
      margin-top: 8px;
    }

    /* ── FOOTER ── */
    footer {
      background: #060606;
      border-top: 1px solid var(--border);
      padding: 72px 80px 40px;
    }
    .footer-grid {
      display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 60px; margin-bottom: 60px;
    }
    .footer-brand-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 28px; font-weight: 300; color: var(--cream);
      letter-spacing: 0.1em; margin-bottom: 4px;
    }
    .footer-brand-sub {
      font-size: 8px; letter-spacing: 0.5em; color: var(--gold);
      text-transform: uppercase; margin-bottom: 20px;
    }
    .footer-desc {
      font-size: 10px; color: var(--grey-mid);
      letter-spacing: 0.1em; line-height: 1.9;
      max-width: 260px; margin-bottom: 28px;
    }
    .social-links { display: flex; gap: 16px; }
    .social-link {
      width: 36px; height: 36px; border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      color: var(--cream-dim); text-decoration: none;
      font-size: 10px; transition: all 0.3s; cursor: none;
    }
    .social-link:hover { border-color: var(--gold); color: var(--gold); }
    .footer-col h4 {
      font-size: 8px; letter-spacing: 0.4em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 24px; font-weight: 500;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 12px; }
    .footer-col ul li a {
      color: var(--grey-mid); text-decoration: none; font-size: 10px;
      letter-spacing: 0.15em; transition: color 0.3s;
    }
    .footer-col ul li a:hover { color: var(--cream); }
    .footer-bottom {
      padding-top: 32px; border-top: 1px solid var(--border);
      display: flex; justify-content: space-between; align-items: center;
    }
    .footer-copy { font-size: 9px; color: var(--grey-mid); letter-spacing: 0.15em; }
    .footer-legal { display: flex; gap: 24px; }
    .footer-legal a {
      font-size: 9px; color: var(--grey-mid); text-decoration: none;
      letter-spacing: 0.1em; transition: color 0.3s;
    }
    .footer-legal a:hover { color: var(--cream); }

    /* ── MOBILE MENU ── */
    .mobile-menu-btn {
      display: none; background: none; border: none;
      color: var(--cream); cursor: none; flex-direction: column;
      gap: 5px; padding: 4px;
    }
    .mobile-menu-btn span {
      display: block; width: 22px; height: 1px; background: var(--cream);
      transition: all 0.3s;
    }

    /* ── CART DRAWER ── */
    .cart-drawer {
      position: fixed; top: 0; right: -420px;
      width: 420px; height: 100vh; background: #0e0e0e;
      border-left: 1px solid var(--border); z-index: 200;
