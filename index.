    .modal-section-label { font-size: 8px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--grey-mid); margin-bottom: 12px; }
    .size-grid { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 28px; }
    .size-btn {
      padding: 10px 20px; border: 1px solid var(--border);
      background: none; color: var(--cream-dim);
      font-family: 'Montserrat', sans-serif; font-size: 9px;
      letter-spacing: 0.2em; cursor: none; transition: all 0.25s;
    }
    .size-btn:hover, .size-btn.selected { border-color: var(--gold); color: var(--gold); }
    .modal-add-btn {
      width: 100%; padding: 15px; background: var(--gold); border: none;
      color: var(--noir); font-family: 'Montserrat', sans-serif;
      font-size: 9px; letter-spacing: 0.4em; text-transform: uppercase;
      cursor: none; font-weight: 500; transition: background 0.3s;
      margin-bottom: 12px;
    }
    .modal-add-btn:hover { background: var(--gold-light); }
    .modal-cancel {
      width: 100%; padding: 10px; background: none; border: 1px solid var(--border);
      color: var(--grey-mid); font-family: 'Montserrat', sans-serif;
      font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase;
      cursor: none; transition: all 0.25s;
    }
    .modal-cancel:hover { border-color: var(--cream-dim); color: var(--cream); }

    /* ── REVEAL ANIMATIONS ── */
    .reveal {
      opacity: 0; transform: translateY(40px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }

    /* ── RESPONSIVE ── */
    @media (max-width: 1100px) {
      .products-grid { grid-template-columns: repeat(2, 1fr); }
      .values-section { grid-template-columns: repeat(2, 1fr); }
      .footer-grid { grid-template-columns: 1fr 1fr; gap: 40px; }
    }

    @media (max-width: 768px) {
      header { padding: 0 24px; }
      .nav-links { display: none; }
      .nav-icons { display: none; }
      .mobile-menu-btn { display: flex; }
      .hero-content { padding: 0 32px 60px; }
      .products-section { padding: 0 12px 60px; }
      .products-grid { grid-template-columns: 1fr; gap: 2px; }
      .products-grid-row2 { grid-template-columns: 1fr; }
      .values-section { grid-template-columns: 1fr 1fr; padding: 60px 24px; }
      .newsletter { grid-template-columns: 1fr; gap: 40px; padding: 60px 24px; }
      .footer-grid { grid-template-columns: 1fr; gap: 36px; }
      footer { padding: 48px 24px 32px; }
      .editorial-content { padding: 40px 32px; }
      .size-strip { flex-direction: column; gap: 24px; padding: 40px 24px; text-align: center; }
      body { cursor: auto; }
      .cursor, .cursor-ring { display: none; }
    }
  </style>
